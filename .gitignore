# IDE folders
.idea/
.vs/
.vscode/*

# Caches
__pycache__
.mypy_cache
.cache/

# Original files
orig/*/*
!orig/*/.gitkeep
*.dol
*.rel
*.elf
*.o
*.map
*.MAP

# Build files
build/
build32/
.ninja_*
build.ninja

# decompctx output
ctx.*
*.ctx

# Generated configs
objdiff.json
compile_commands.json

# Miscellaneous
/*.txt
!requirements.txt
*.exe

# ROM / disc images (provide your own)
*.iso
*.gcm
*.ciso
rom/

# Claude integration — API secrets and per-save conversation data
# (build32/ above already covers these, but listed explicitly as a safety net)
**/save/api_key.txt
**/save/claude_*.txt
**/save/claude_debug.log

# For saving work files into (like IDB)
temp/

# Ignore the N64 SDK headers since we download them
# NOTE: include/PR/gbi.h and include/PR/ultratypes.h are force-tracked
# (git add -f) because they have TARGET_PC modifications for LE bitfields.
# configure.py skips download when they already exist.
include/PR/
include/gcc/
include/compiler/gcc/stdlib.h
/.claude
*.manifest
